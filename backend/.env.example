# ╔══════════════════════════════════════════════════════════════╗
# ║          YATRIKA — ENVIRONMENT CONFIGURATION GUIDE           ║
# ║                                                              ║
# ║  Copy this file to .env and fill in your actual values.      ║
# ║  NEVER commit your real .env file to GitHub!                 ║
# ╚══════════════════════════════════════════════════════════════╝


# ─── App Settings ──────────────────────────────────────────────────────────────
# APP_NAME     : The display name of the platform (keep as Yatrika)
# APP_ENV      : Set to "production" when deploying to a live server
# DEBUG        : Set to "false" in production to hide error traces
# FRONTEND_URL : The URL where your React frontend is hosted (used for CORS)

APP_NAME=Yatrika
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:5173


# ─── MySQL Database ────────────────────────────────────────────────────────────
# The main relational database. Stores Users, Bookings, Tourist Places,
# Guide Profiles, OTP tokens, Notifications, etc.
#
# HOW TO GET:
#   Option A — Docker (easiest):
#     Just run `docker-compose up -d`. The Docker user/password are pre-set.
#     Connection string → mysql+pymysql://yatrika_user:yatrika_pass_2025@localhost:3306/yatrika_db
#
#   Option B — Local MySQL (already installed on your machine):
#     1. Open MySQL (via terminal or MySQL Workbench)
#     2. Run:  CREATE DATABASE yatrika_db;
#     3. Replace 'root' with your MySQL username and 'yourpassword' with your password.

# ▼ Use ONE of these (comment out the other):
DATABASE_URL=mysql+pymysql://yatrika_user:yatrika_pass_2025@localhost:3306/yatrika_db
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/yatrika_db


# ─── MongoDB Database ──────────────────────────────────────────────────────────
# Used for activity/event logging and the anomaly detection system.
# Stores: login events, IP addresses, suspicious activity logs.
# This data is used by the Admin Dashboard security panel.
#
# HOW TO GET:
#   Option A — Docker:
#     Auto-configured by docker-compose. Use the URI below as-is.
#
#   Option B — Local MongoDB (already installed):
#     If MongoDB is installed locally without authentication, use the simple URI.
#     Run `mongosh` in terminal to verify it's running.
#
# HOW TO CHECK stored logs:
#   > mongosh
#   > use yatrika_logs
#   > db.activity_logs.find().pretty()
#   Or use MongoDB Compass (GUI): connect to mongodb://localhost:27017

# ▼ Use ONE of these (comment out the other):
MONGODB_URI=mongodb://yatrika_user:yatrika_pass_2025@localhost:27017/yatrika_logs?authSource=admin
# MONGODB_URI=mongodb://localhost:27017/yatrika_logs

MONGODB_DB_NAME=yatrika_logs


# ─── Redis ─────────────────────────────────────────────────────────────────────
# Used for: OTP rate limiting (max 3 OTPs per 15 min), login attempt tracking
# (max 5 failed logins per 10 min), and JWT token blacklisting after logout.
#
# HOW TO GET:
#   Option A — Docker: Auto-configured. Default URI works as-is.
#   Option B — Local Redis: Install via `brew install redis` (Mac) or
#               `sudo apt install redis` (Linux), then run `redis-server`.

REDIS_URL=redis://localhost:6379/0


# ─── JWT Authentication ────────────────────────────────────────────────────────
# Used to sign and verify user login tokens. MUST be a long, random secret string.
# Compromise of JWT_SECRET = anyone can forge login sessions.
#
# HOW TO GENERATE a secure secret:
#   Run in your terminal: openssl rand -hex 32
#   Copy the output and paste it as JWT_SECRET below.
#
# ACCESS_TOKEN_EXPIRE_MINUTES : How long a login session lasts (default: 15 min)
# REFRESH_TOKEN_EXPIRE_DAYS   : How long before a user must re-login (default: 7 days)

JWT_SECRET=REPLACE_THIS_WITH_OUTPUT_OF_openssl_rand_-hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# ─── GitHub OAuth2 ─────────────────────────────────────────────────────────────
# Enables "Sign in with GitHub" on the Login page.
#
# HOW TO GET:
#   1. Go to: https://github.com/settings/developers
#   2. Click "New OAuth App"
#   3. Set "Authorization callback URL" to:
#      http://localhost:8000/api/v1/auth/github/callback
#   4. Copy "Client ID" and generate a "Client Secret"
#
# OPTIONAL: If you don't need GitHub login, leave these as-is. GitHub login
# button will simply not work, but everything else will function normally.

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback


# ─── Gmail SMTP (Email Service) ────────────────────────────────────────────────
# Used for sending OTP verification emails, booking confirmations,
# guide approval/rejection emails, and password reset codes.
#
# IMPORTANT: Do NOT use your regular Gmail password here.
# You MUST use a "Google App Password" (a special 16-character code).
#
# HOW TO GET a Google App Password:
#   1. Go to: https://myaccount.google.com/security
#   2. Under "How you sign in to Google" → click "2-Step Verification" (must be ON)
#   3. Search for "App Passwords" at the bottom OR go to:
#      https://myaccount.google.com/apppasswords
#   4. Select App → "Mail", Device → "Other (custom name)" → type "Yatrika"
#   5. Click "Generate" → copy the 16-character code (e.g., abcd efgh ijkl mnop)
#   6. Paste it below (remove spaces): GMAIL_APP_PASSWORD=abcdefghijklmnop
#
# OPTIONAL: If not configured, the platform still works but won't send emails.

GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx


# ─── Cloudinary (Image Storage) ────────────────────────────────────────────────
# Used for storing guide profile photos uploaded via the Guide Dashboard.
# Cloudinary has a generous free tier (25 GB storage, 25 GB bandwidth/month).
#
# HOW TO GET:
#   1. Sign up free at: https://cloudinary.com
#   2. Go to your Dashboard (home page after login)
#   3. Copy "Cloud Name", "API Key", and "API Secret" from the dashboard panel.
#
# OPTIONAL: If not configured, image uploads fail but all other features work.

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
